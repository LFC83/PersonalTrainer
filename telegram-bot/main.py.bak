def load_garmin_data():
    """Carrega dados consolidados do Garmin"""
    try:
        path = os.path.join(DATA_DIR, 'garmin_data_consolidated.json')
        if os.path.exists(path):
            with open(path, 'r') as f:
                return json.load(f)
    except Exception as e:
        logger.error(f"Erro ao carregar dados: {e}")
    return None

def load_activities():
    """Carrega histórico de atividades"""
    try:
        path = os.path.join(DATA_DIR, 'activities.json')
        if os.path.exists(path):
            with open(path, 'r') as f:
                return json.load(f)
    except Exception as e:
        logger.error(f"Erro ao carregar atividades: {e}")
    return []

def parse_garmin_history(raw_data):
    """Converte dados brutos para formato processável"""
    if not raw_data:
        return []
    
    history = []
    for d in raw_data:
        try:
            # Extração robusta de HRV
            hrv = None
            if 'hrv' in d and isinstance(d['hrv'], dict):
                hrv_summary = d['hrv'].get('hrvSummary', {})
                if isinstance(hrv_summary, dict):
                    hrv = hrv_summary.get('lastNightAvg') or hrv_summary.get('weeklyAvg')
            
            # Extração robusta de RHR
            rhr = None
            if 'stats' in d and isinstance(d['stats'], dict):
                rhr = d['stats'].get('restingHeartRate') or d['stats'].get('minHeartRate')
            
            # Extração robusta de Sleep Score
            sleep = None
            if 'sleep' in d and isinstance(d['sleep'], dict):
                daily_sleep = d['sleep'].get('dailySleepDTO', {})
                if isinstance(daily_sleep, dict):
                    sleep_scores = daily_sleep.get('sleepScores', {})
                    if isinstance(sleep_scores, dict):
                        overall = sleep_scores.get('overall', {})
                        if isinstance(overall, dict):
                            sleep = overall.get('value')
                        elif isinstance(overall, (int, float)):
                            sleep = overall
            
            # Extração de Training Load
            training_load = None
            if 'stats' in d and isinstance(d['stats'], dict):
                training_load = d['stats'].get('trainingLoad') or d['stats'].get('intensityMinutesGoal')
            
            history.append({
                'date': d.get('date'),
                'hrv': hrv,
                'rhr': rhr,
                'sleep': sleep,
                'training_load': training_load
            })
        except Exception as e:
            logger.error(f"Erro ao processar dia {d.get('date')}: {e}")
            continue
    
    return history

def format_activity(activity):
    """
    Formata uma atividade para exibição - suporta múltiplos formatos e faz merge de dados.
    Prioriza dados manuais (sport, intensity, load) mas adiciona dados Garmin (HR, calories).
    """
    
    # Inicializar valores default
    result = {
        'date': None,
        'sport': 'Desconhecido',
        'duration_min': 0,
        'distance_km': None,
        'avg_hr': None,
        'calories': None,
        'intensity': None,
        'load': None,
        'raw': activity
    }
    
    # ===== EXTRAÇÃO DE DATA =====
    if 'date' in activity:
        result['date'] = activity['date']
    elif 'startTimeLocal' in activity or 'startTimeGMT' in activity or 'beginTimestamp' in activity:
        start_time = activity.get('startTimeLocal') or activity.get('startTimeGMT') or activity.get('beginTimestamp') or ''
        result['date'] = start_time.split('T')[0] if 'T' in start_time else start_time[:10] if len(start_time) >= 10 else None
    
    # ===== EXTRAÇÃO DE SPORT =====
    # Prioridade 1: Campo 'sport' (manual)
    if 'sport' in activity:
        result['sport'] = activity['sport']
    # Prioridade 2: activityName (Garmin)
    elif 'activityName' in activity:
        result['sport'] = activity['activityName']
    # Prioridade 3: activityType (Garmin)
    elif 'activityType' in activity:
        if isinstance(activity['activityType'], dict):
            result['sport'] = activity['activityType'].get('typeKey') or activity['activityType'].get('typeId') or 'Desconhecido'
        elif isinstance(activity['activityType'], str):
            result['sport'] = activity['activityType']
    # Prioridade 4: sportType (Garmin)
    elif 'sportType' in activity:
        sport_obj = activity['sportType']
        if isinstance(sport_obj, dict):
            result['sport'] = sport_obj.get('sportTypeKey') or sport_obj.get('sportTypeId') or 'Desconhecido'
        elif isinstance(sport_obj, str):
            result['sport'] = sport_obj
    
    # Limpar nome do sport
    if result['sport'] and result['sport'] != 'Desconhecido':
        result['sport'] = result['sport'].replace('_', ' ').title()
    
    # ===== EXTRAÇÃO DE DURAÇÃO =====
    if 'duration' in activity:
        # Formato manual: já em minutos ou segundos?
        duration_val = activity['duration']
        # Se < 500, assumir que já está em minutos (ex: 115.0)
        # Se >= 500, assumir que está em segundos (ex: 3600)
        if duration_val < 500:
            result['duration_min'] = duration_val
        else:
            result['duration_min'] = duration_val / 60
    
    # ===== EXTRAÇÃO DE DISTÂNCIA =====
    if 'distance' in activity:
        distance_val = activity['distance']
        # Se < 100, assumir que já está em km
        # Se >= 100, assumir que está em metros
        if distance_val < 100:
            result['distance_km'] = distance_val if distance_val > 0 else None
        else:
            result['distance_km'] = distance_val / 1000 if distance_val > 0 else None
    
    # ===== EXTRAÇÃO DE HR =====
    # Prioridade: avg_hr (manual) > averageHR (Garmin)
    if 'avg_hr' in activity and activity['avg_hr'] not in [None, 'N/A', 0]:
        result['avg_hr'] = activity['avg_hr']
    elif 'averageHR' in activity:
        result['avg_hr'] = activity['averageHR']
    elif 'avgHr' in activity:
        result['avg_hr'] = activity['avgHr']
    elif 'averageHeartRate' in activity:
        result['avg_hr'] = activity['averageHeartRate']
    
    # ===== EXTRAÇÃO DE CALORIAS =====
    if 'calories' in activity and activity['calories'] not in [None, 'N/A', 0]:
        result['calories'] = activity['calories']
    elif 'kilocalories' in activity:
        result['calories'] = activity['kilocalories']
    
    # ===== EXTRAÇÃO DE INTENSITY (manual) =====
    if 'intensity' in activity and activity['intensity']:
        result['intensity'] = activity['intensity']
    
    # ===== EXTRAÇÃO DE LOAD (manual) =====
    if 'load' in activity and activity['load'] not in [None, 'N/A', 0]:
        result['load'] = activity['load']
    
    # ===== INFERÊNCIAS =====
    # Se sport ainda é desconhecido, tentar inferir
    if result['sport'] == 'Desconhecido':
        if result['distance_km'] and result['distance_km'] > 10:
            result['sport'] = 'Ciclismo/Corrida'
        elif result['duration_min'] > 60 and not result['distance_km']:
            result['sport'] = 'Ginásio/Força'
    
    # Arredondar valores
    if result['duration_min']:
        result['duration_min'] = round(result['duration_min'], 1)
    if result['distance_km']:
        result['distance_km'] = round(result['distance_km'], 2)
    
    return result

def list_data_files():
    """Lista arquivos de dados disponíveis"""
    try:
        files = [f for f in os.listdir(DATA_DIR) if f.startswith('garmin_data_') and f.endswith('.json')]
        return sorted(files)
    except Exception as e:
        logger.error(f"Erro ao listar arquivos: {e}")
        return []

def create_import_request(days=7):
    """
    Cria flag file para importação histórica.
    O garmin-fetcher irá processar este pedido no próximo ciclo.
    """
    try:
        flag_path = os.path.join(DATA_DIR, 'import_request.json')
        request = {
            'days': days,
            'requested_at': datetime.now().isoformat(),
            'status': 'pending'
        }
        
        with open(flag_path, 'w') as f:
            json.dump(request, f, indent=2)
        
        logger.info(f"Flag de importação criada: {days} dias")
        return True
        
    except Exception as e:
        logger.error(f"Erro ao criar flag de importação: {e}")
        return False

def create_sync_request():
    """
    Cria flag file para sincronização de hoje.
    O garmin-fetcher irá processar este pedido no próximo ciclo.
    """
    try:
        flag_path = os.path.join(DATA_DIR, 'sync_request.json')
        request = {
            'requested_at': datetime.now().isoformat(),
            'status': 'pending'
        }
        
        with open(flag_path, 'w') as f:
            json.dump(request, f, indent=2)
        
        logger.info("Flag de sincronização criada")
        return True
        
    except Exception as e:
        logger.error(f"Erro ao criar flag de sincronização: {e}")
        return False

def check_request_status(request_type='import'):
    """
    Verifica o status de um pedido (import ou sync).
    Retorna: 'pending', 'completed', 'failed', ou None se não existe.
    """
    try:
        filename = f'{request_type}_request.json'
        flag_path = os.path.join(DATA_DIR, filename)
        
        if not os.path.exists(flag_path):
            return None
        
        with open(flag_path, 'r') as f:
            request = json.load(f)
        
        return request.get('status')
        
    except Exception as e:
        logger.error(f"Erro ao verificar status: {e}")
        return None

def wait_for_request_completion(request_type='import', timeout=120):
    """
    Aguarda até que um pedido seja completado ou timeout.
    Retorna True se completado com sucesso, False caso contrário.
    """
    start_time = time.time()
    
    while time.time() - start_time < timeout:
        status = check_request_status(request_type)
        
        if status == 'completed':
            return True
        elif status == 'failed':
            return False
        
        time.sleep(2)  # Verificar a cada 2 segundos
    
    logger.warning(f"Timeout aguardando {request_type}")
    return False

def check_garmin_fetcher_health():
    """
    Verifica se o garmin-fetcher está funcional verificando:
    1. Se o arquivo consolidado existe
    2. Se foi atualizado recentemente (últimas 2 horas)
    """
    try:
        consolidated_path = os.path.join(DATA_DIR, 'garmin_data_consolidated.json')
        
        if not os.path.exists(consolidated_path):
            return False, "Arquivo consolidado não existe"
        
        # Verificar última modificação
        mod_time = os.path.getmtime(consolidated_path)
        age_hours = (time.time() - mod_time) / 3600
        
        if age_hours > 2:
            return False, f"Dados desatualizados (última atualização há {age_hours:.1f}h)"
        
        # Verificar se tem conteúdo
        with open(consolidated_path, 'r') as f:
            data = json.load(f)
            if not data or len(data) == 0:
                return False, "Arquivo consolidado vazio"
        
        return True, "OK"
        
    except Exception as e:
        return False, f"Erro ao verificar: {e}"

def cleanup_old_flags():
    """
    Limpa flags pending com mais de 5 minutos.
    Retorna: (flags_limpos, mensagem)
    """
    cleaned = 0
    messages = []
    
    for flag_name in ['import_request.json', 'sync_request.json']:
        flag_path = os.path.join(DATA_DIR, flag_name)
        
        if os.path.exists(flag_path):
            try:
                with open(flag_path, 'r') as f:
                    data = json.load(f)
                
                status = data.get('status')
                
                if status == 'pending':
                    requested_at = datetime.fromisoformat(data['requested_at'])
                    age_seconds = (datetime.now() - requested_at).total_seconds()
                    
                    if age_seconds > 300:  # Mais de 5 minutos
                        data['status'] = 'completed'
                        data['processed_at'] = datetime.now().isoformat()
                        data['cleaned_by'] = 'auto_cleanup'
                        
                        with open(flag_path, 'w') as f:
                            json.dump(data, f, indent=2)
                        
                        cleaned += 1
                        messages.append(f"✅ {flag_name.replace('_request.json', '')}: pending há {int(age_seconds)}s → completed")
                    else:
                        messages.append(f"⏳ {flag_name.replace('_request.json', '')}: pending recente ({int(age_seconds)}s)")
                elif status == 'completed':
                    messages.append(f"✅ {flag_name.replace('_request.json', '')}: já completed")
                else:
                    messages.append(f"❓ {flag_name.replace('_request.json', '')}: status {status}")
                    
            except Exception as e:
                messages.append(f"❌ Erro em {flag_name}: {e}")
        else:
            messages.append(f"ℹ️  {flag_name.replace('_request.json', '')}: não existe")
    
    return cleaned, messages

def reorganize_activities():
    """
    Reorganiza activities.json: remove duplicados e ordena por data.
    Retorna: (duplicados_removidos, total_final, mensagens)
    """
    activities_path = os.path.join(DATA_DIR, 'activities.json')
    messages = []
    
    if not os.path.exists(activities_path):
        return 0, 0, ["ℹ️  activities.json não existe"]
    
    try:
        with open(activities_path, 'r') as f:
            activities = json.load(f)
        
        original_count = len(activities)
        messages.append(f"📊 Total original: {original_count} atividades")
        
        # Remover duplicados usando ID
        seen_ids = set()
        unique_activities = []
        
        for act in activities:
            act_id = act.get('activityId') or act.get('id')
            
            # Se não tem ID, usar combinação data+sport+duração
            if not act_id:
                date_str = act.get('date') or act.get('startTimeLocal', '')[:10]
                sport = act.get('sport') or act.get('activityName', 'unknown')
                duration = act.get('duration', 0)
                act_id = f"{date_str}_{sport}_{duration}"
            
            if act_id not in seen_ids:
                seen_ids.add(act_id)
                unique_activities.append(act)
        
        duplicates_removed = original_count - len(unique_activities)
        
        if duplicates_removed > 0:
            messages.append(f"🗑️  Removidos {duplicates_removed} duplicados")
        
        # Ordenar por data
        def get_activity_date(act):
            if 'date' in act:
                return act['date']
            start_time = act.get('startTimeLocal') or act.get('startTimeGMT') or act.get('beginTimestamp') or ''
            if 'T' in start_time:
                return start_time.split('T')[0]
            return start_time[:10] if len(start_time) >= 10 else '0000-00-00'
        
        unique_activities.sort(key=get_activity_date, reverse=True)
        
        # Limitar a 100 mais recentes
        trimmed = 0
        if len(unique_activities) > 100:
            trimmed = len(unique_activities) - 100
            unique_activities = unique_activities[:100]
            messages.append(f"✂️  Limitadas a 100 (removidas {trimmed} mais antigas)")
        
        # Salvar
        with open(activities_path, 'w') as f:
            json.dump(unique_activities, f, indent=2)
        
        messages.append(f"✅ Activities.json reorganizado: {len(unique_activities)} atividades")
        
        # Mostrar últimas 3
        if len(unique_activities) >= 3:
            messages.append("\n📋 Últimas 3:")
            for i, act in enumerate(unique_activities[:3], 1):
                date = get_activity_date(act)
                sport = act.get('sport') or act.get('activityName') or 'Desconhecido'
                duration = act.get('duration', 0)
                duration_min = duration if duration < 500 else duration / 60
                messages.append(f"  {i}. {date} - {sport} ({duration_min:.1f}min)")
        
        return duplicates_removed, len(unique_activities), messages
        
    except Exception as e:
        return 0, 0, [f"❌ Erro: {e}"]

def auto_cleanup_on_startup():
    """Executa cleanup automático no arranque do bot"""
    try:
        cleaned_flags, _ = cleanup_old_flags()
        if cleaned_flags > 0:
            logger.info(f"Auto-cleanup: {cleaned_flags} flags limpos no arranque")
    except Exception as e:
        logger.error(f"Erro no auto-cleanup: {e}")

